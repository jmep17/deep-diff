node_modules/
dist/
dist-electron/
.DS_Store
npm-debug.log*
pnpm-debug.log*
cypress/videos/
cypress/screenshots/
.cache/
.claude.local.md

# Package manager store
.pnpm-store/

# Local agent tooling (machine-specific, not shared)
.agents/
.aider-desk/
.codex/
.serena/
.claude/

# Nested git fixtures — restore from the committed bundles via scripts/restore-fixtures.sh
mock-repositories/auth0-routes-fixture/
mock-workspace/storefront-auth0/
mock-workspace/marketing-site/

# ─── Secrets / credentials (never commit) ───────────────────────────────
# Applies at every depth (**/) so secrets in any nested repo added for
# visual diff / sidecar are also excluded. Templates whitelisted below.

# Env files
.env
.env.*
**/.env
**/.env.*
!.env.example
!.env.sample
!.env.template
!**/.env.example
!**/.env.sample
!**/.env.template

# Private keys / certificates
*.pem
*.key
*.p12
*.pfx
*.p8
*.crt
*.cer
*.der
*.keystore
*.jks
*.ppk
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/*.p8
id_rsa
id_dsa
id_ecdsa
id_ed25519
**/id_rsa
**/id_ed25519

# Cloud / service credentials
.netrc
.npmrc
**/.npmrc
.pypirc
credentials
credentials.json
**/credentials.json
gha-creds-*.json
service-account*.json
**/service-account*.json
*-key.json
gcp-*.json
aws.json
.aws/
.gcp/

# Token / secret stashes
secrets.*
secret.*
*.secret
*.secrets
**/secrets.*
*token*.json
*.token
.htpasswd
auth.json
**/auth.json

# Local overlay storage (may hold real auth config for diffed repos)
overlays/
**/overlays/

# Run artifacts that capture added-repo dev-server stdout/stderr (can leak secrets)
*.log
*.trace
**/*.trace
visual-diff.trace
scripts/electron-app/run.log
deep-diff-logs/
**/deep-diff-logs/
# keep pre-existing debug-log patterns above; allow nothing under logs/
logs/
**/logs/
